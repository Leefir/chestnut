#!/bin/sh
if git diff --cached --name-only --diff-filter=ACM | grep -qE '\.tsx?$'; then
  cd "$(git rev-parse --show-toplevel)"
  npx tsc --noEmit --incremental --tsBuildInfoFile .tsbuildinfo || {
    echo "❌ tsc (src) 失败，commit 已阻止（--no-verify 可豁免）"
    exit 1
  }
  npx tsc -p tsconfig.test.json --noEmit --incremental --tsBuildInfoFile .tsbuildinfo.test || {
    echo "❌ tsc (tests) 失败，commit 已阻止（--no-verify 可豁免）"
    exit 1
  }
fi
